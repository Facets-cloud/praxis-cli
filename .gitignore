# Built binary
/praxis

# Go test/build artifacts
*.test
*.out
*.exe
coverage.txt

# Pre-existing test leak: some cmd/* test writes catalog skill files
# relative to its CWD instead of to t.TempDir(), polluting the repo
# tree with /cmd/praxis*/ folders containing real-looking SKILL.md
# contents. Until that test is fixed, ignore the leak so it doesn't
# litter `git status` on every test run.
/cmd/praxis/
/cmd/praxis-*/

# goreleaser output
/dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# macOS
.DS_Store

# Local config
.env
.env.local

# Claude Code state — agent transcripts, plans, worktrees.
# DO commit project-level settings.json (defines deny rules for
# credential files — see .claude/settings.json comment).
/.claude/*
!/.claude/settings.json

# codegraph index
/.codegraph/

# Local AI-host state generated by praxis skill sourcing / local mode:
#   .praxis/  — project profile pointer, install receipt, MCP snapshot
#   .agents/  — sourced praxis-* skills installed into the AI host
#   .gemini/  — Gemini CLI agents/skills install target
/.praxis/
/.agents/
/.gemini/
